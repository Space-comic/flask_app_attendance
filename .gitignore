# Python 字节码与缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 虚拟环境
venv/
.venv/
env/

# IDE / 编辑器
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Flask / 运行时产物
instance/
*.log
logs/
*.sqlite
*.db

# 上传 / 临时文件
static/uploads/
tmp/
*.tmp

# === 隐私数据：人脸照片不进仓库（合规要求）===
images_db/*.jpg
images_db/*.jpeg
images_db/*.png
# 保留目录占位
!images_db/.gitkeep

# 测试图片 / 本地数据集
test_images/
sample_images/
测试用的人脸与合照/

# Excel 导出产物
*.xlsx
!docs/**/*.xlsx
